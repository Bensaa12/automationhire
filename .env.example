# ============================================================
# AutomationHire.co.uk — Environment Variables
# Copy this file to .env.local for local development.
# Add ALL of these to Vercel Dashboard → Settings → Environment Variables
# ============================================================

# --- SUPABASE ---
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# IMPORTANT: Service role key bypasses RLS — keep it server-side only (API routes)

# --- STRIPE ---
# Found in: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
# Found in: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing Secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create these in: Stripe Dashboard → Products
# Create one product "AutomationHire Listing" with 6 recurring prices:
STRIPE_PRICE_GROWTH_MONTHLY=price_...
STRIPE_PRICE_GROWTH_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_AGENCY_MONTHLY=price_...
STRIPE_PRICE_AGENCY_YEARLY=price_...

# --- RESEND ---
# Found in: resend.com → API Keys
RESEND_API_KEY=re_...
# Your verified sending domain (verify at resend.com → Domains)
RESEND_FROM_EMAIL=noreply@automationhire.co.uk
RESEND_REPLY_TO=hello@automationhire.co.uk

# --- ANTHROPIC (Talk2Sell AI Chat) ---
# Found in: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# --- SITE ---
NEXT_PUBLIC_SITE_URL=https://automationhire.co.uk
ADMIN_EMAIL=admin@automationhire.co.uk

# --- OPTIONAL: Rate limiting ---
# (Add Upstash Redis later for production rate limiting)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
